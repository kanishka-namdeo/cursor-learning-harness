# Secrets - never commit API keys
.env
.env.*
.cursor/llm.env

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Python
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.egg-info

# Python runtime
pip-log.txt
pip-delete-this-directory.txt

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Typing
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/

# Auto-generated state (do not track)
.cursor/hooks/state/
!.cursor/hooks/state/.gitkeep

# Logs
*.log
logs/

# Distribution
*.tar.gz
*.whl

# ---------------------------------------------------------------
# TARGET WORKSPACE .gitignore GUIDANCE
# ---------------------------------------------------------------
# After running setup-hooks.ps1 or setup-hooks.sh in an existing
# project, the TARGET workspace should add these entries to its
# own .gitignore to prevent committing runtime state and secrets:
#
#   # Cursor Learning Harness (runtime state)
#   .cursor/hooks/state/
#   !.cursor/hooks/state/.gitkeep
#   .cursor/llm.env
# ---------------------------------------------------------------
