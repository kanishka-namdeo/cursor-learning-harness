{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 session_start.py"
      },
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 summarizer_daemon.py --start"
      }
    ],
    "sessionEnd": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 session_end.py",
        "timeout": 30
      },
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 sentiment_arc_trigger.py"
      }
    ],
    "preToolUse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 pre_tool_use.py"
      }
    ],
    "postToolUse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 post_tool_use.py"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 post_tool_use_failure.py"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 before_shell_execution.py"
      }
    ],
    "afterShellExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_shell_execution.py"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 before_mcp_execution.py"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_mcp_execution.py"
      }
    ],
    "subagentStart": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 subagent_start.py"
      }
    ],
    "subagentStop": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 subagent_stop.py"
      }
    ],
    "beforeReadFile": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 before_read_file.py"
      }
    ],
    "afterFileEdit": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_file_edit.py"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 before_submit_prompt.py"
      }
    ],
    "preCompact": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 pre_compact.py"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_agent_response.py"
      },
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 summarizer_trigger.py"
      }
    ],
    "afterAgentThought": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_agent_thought.py"
      }
    ],
    "stop": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 stop.py"
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 before_tab_file_read.py"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "powershell -ExecutionPolicy Bypass -File .cursor/hooks/run-hook.ps1 after_tab_file_edit.py"
      }
    ]
  }
}
